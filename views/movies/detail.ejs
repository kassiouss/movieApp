<%- include('../partials/header', { title: movie.title }) %>

<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">Home</a></li>
    <li class="breadcrumb-item"><a href="/movies">Movies</a></li>
    <li class="breadcrumb-item active"><%= movie.title %></li>
  </ol>
</nav>

<div class="row g-4">
  <div class="col-md-4">
    <% if (movie.image_url) { %>
      <img src="<%= movie.image_url %>" class="img-fluid rounded shadow" alt="<%= movie.title %>" />
    <% } else { %>
      <div class="movie-poster-placeholder rounded d-flex align-items-center justify-content-center bg-secondary text-white" style="height:400px">
        <i class="bi bi-film" style="font-size:4rem"></i>
      </div>
    <% } %>
  </div>
  <div class="col-md-8">
    <h1 class="fw-bold"><%= movie.title %></h1>

    <div class="mb-3">
      <% if (movie.category_name) { %><span class="badge bg-secondary fs-6 me-2"><%= movie.category_name %></span><% } %>
      <% if (movie.release_year) { %><span class="badge bg-dark fs-6"><%= movie.release_year %><% if (movie.release_month) { %>/<%= String(movie.release_month).padStart(2,'0') %><% } %></span><% } %>
    </div>

    <% if (movie.rating) { %>
      <p class="fs-4 mb-2"><i class="bi bi-star-fill text-warning me-1"></i><strong><%= movie.rating %></strong> / 10</p>
    <% } %>

    <% if (movie.duration_minutes) { %>
      <p class="text-muted"><i class="bi bi-clock me-2"></i><strong>Duration:</strong> <%= movie.duration_minutes %> min</p>
    <% } %>

    <% if (movie.description) { %>
      <hr />
      <p class="lead"><%= movie.description %></p>
    <% } %>

    <div class="d-flex gap-2 mt-4">
      <form action="/movies/<%= movie.id %>/favorite" method="POST">
        <button type="submit" class="btn <%= isFavorite ? 'btn-warning' : 'btn-outline-warning' %>">
          <i class="bi bi-heart<%= isFavorite ? '-fill' : '' %>"></i>
        </button>
      </form>
      <a href="/movies" class="btn btn-secondary ms-auto"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
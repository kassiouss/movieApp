<%- include('../partials/header', { title: 'Add Movie' }) %>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-header bg-dark text-white">
        <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Add New Movie</h4>
      </div>
      <div class="card-body">
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form action="/movies" method="POST">
          <%- include('../partials/movie-form', { movie: {} }) %>
          <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-warning">Add Movie</button>
            <a href="/movies" class="btn btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>